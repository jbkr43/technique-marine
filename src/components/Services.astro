---
import services from '../content/services.json';
---

<section class="services" id="services">
  <div class="services__inner">
    <div class="services__header">
      <h2 class="services__title">Highlighted Services</h2>
      <p class="services__sub">No matter what question, concern, or vision you have for your boat, we can help.</p>
    </div>
    <div class="services__grid">
      {services.map((service) => (
        <div class="services__card">
          <h3 class="services__card-title">{service.title}</h3>
          <p class="services__card-desc">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background-color: var(--color-cream);
    padding: var(--section-padding);
  }

  .services__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .services__header {
    text-align: center;
    margin-bottom: 56px;
  }

  .services__title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 16px;
  }

  .services__sub {
    font-size: 1rem;
    color: var(--color-navy);
    opacity: 0.7;
    max-width: 520px;
    margin: 0 auto;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-bottom: 48px;
  }

  .services__card {
    background-color: var(--color-white);
    border: 1px solid rgba(30, 45, 61, 0.1);
    border-top: 3px solid var(--color-gold);
    border-radius: 6px;
    padding: 36px 28px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .services__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(30, 45, 61, 0.1);
  }

  .services__card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .services__card-desc {
    font-size: 0.95rem;
    color: var(--color-navy);
    opacity: 0.75;
    line-height: 1.7;
  }

  .services__cta-line {
    text-align: center;
    font-size: 1rem;
    font-style: italic;
    color: var(--color-navy);
    opacity: 0.7;
    margin-bottom: 28px;
  }

  @media (max-width: 768px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
  }
</style>