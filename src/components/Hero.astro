---
import site from '../content/site.json';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<section class="hero" id="hero">
  <div class="hero__inner">
    <div class="hero__text">
      <p class="hero__tagline">{site.serviceArea}</p>
      <h1 class="hero__headline">{site.hero.headline}</h1>
      <p class="hero__sub">{site.tagline}</p>
      <p class="hero__one-call">{site.hero.subheadline}</p>
      <div class="hero__actions">
        <a href="#contact" class="btn">Request Quote</a>
        <a href="tel:+19104651175" class="hero__phone">(910) 465-1175</a>
      </div>
    </div>
    <div class="hero__logo">
      <img src={`${base}logos/hero.png`} alt="Technique Marine service vehicle" />
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--color-navy);
    color: var(--color-cream);
    padding: 80px 24px;
  }

  .hero__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
  }

  .hero__text {
    flex: 1;
    max-width: 580px;
  }

  .hero__tagline {
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 16px;
    font-weight: 600;
  }

  .hero__headline {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-cream);
    margin-bottom: 20px;
  }

  .hero__sub {
    font-size: 1.1rem;
    color: var(--color-steel);
    margin-bottom: 12px;
    line-height: 1.6;
  }

  .hero__one-call {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-gold);
    margin-bottom: 36px;
    letter-spacing: 0.02em;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }

  .hero__phone {
    color: var(--color-cream);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .hero__phone:hover {
    color: var(--color-gold);
  }

  .hero__logo {
    flex-shrink: 0;
    width: 400px;
    border-radius: 6px;
    border: 2px solid var(--color-gold);
    overflow: hidden;
  }

  .hero__logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .hero__logo {
      display: none;
    }

    .hero__inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>