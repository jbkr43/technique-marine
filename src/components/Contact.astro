---
import site from '../content/site.json';
---

<section class="contact" id="contact">
  <div class="contact__inner">
    <div class="contact__header">
      <h2 class="contact__title">Let's Connect</h2>
      <p class="contact__sub">Ready to get your boat back on the water? Reach out and we'll get you sorted.</p>
    </div>
    <div class="contact__grid">
      <div class="contact__info">
        <a href={`tel:${site.phone.replace(/\D/g, '')}`} class="contact__card">
          <svg class="contact__card-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.48h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10a16 16 0 0 0 6.09 6.09l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span class="contact__card-label">Phone</span>
          <span class="contact__card-value">{site.phone}</span>
        </a>
        <a href={`mailto:${site.email}`} class="contact__card">
          <svg class="contact__card-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span class="contact__card-label">Email</span>
          <span class="contact__card-value">{site.email}</span>
        </a>
        <div class="contact__card contact__card--map">
          <span class="contact__card-label">Service Area</span>
          <span class="contact__card-value">Cape Fear, NC — within an hour of south Wilmington</span>
          <div class="contact__map" id="contactMap" data-center='{"lat":34.2,"lng":-78.1}' data-radius="30"></div>
        </div>
      </div>
      <form class="contact__form" id="contactForm" action="https://formspree.io/f/xrevvdpw" method="POST">
        <input type="hidden" name="_next" value="https://techniquemarine.com/thank-you" />
        <input type="text" name="_gotcha" class="contact__honeypot" tabindex="-1" autocomplete="off" />
        <div class="contact__field">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" placeholder="Your name" autocomplete="name" required />
          <span class="contact__error" id="nameError"></span>
        </div>
        <div class="contact__field">
          <label for="phone">Phone</label>
          <input type="tel" id="phone" name="phone" placeholder="(910) 555-0000" autocomplete="tel" />
          <span class="contact__error" id="phoneError"></span>
        </div>
        <div class="contact__field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" autocomplete="email" required />
          <span class="contact__error" id="emailError"></span>
        </div>
        <div class="contact__field">
          <label for="boat">Boat Type</label>
          <input type="text" id="boat" name="boat" placeholder="e.g. 24' Center Console, Sailboat, Pontoon" autocomplete="off" required />
          <span class="contact__error" id="boatError"></span>
        </div>
        <div class="contact__field">
          <label for="message">What do you need?</label>
          <textarea id="message" name="message" rows="4" placeholder="Describe your boat and what's going on..." required></textarea>
          <span class="contact__error" id="messageError"></span>
        </div>
        <div class="contact__error contact__error--banner" id="formError" hidden></div>
        <button type="submit" class="btn" id="submitBtn">
          <span class="btn__text">Send Message</span>
          <svg class="btn__spinner" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5">
            <circle cx="12" cy="12" r="10" opacity="0.25" />
            <path d="M12 2a10 10 0 0 1 10 10" />
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>
<script is:inline>
  (function() {
    var el = document.getElementById('contactMap');
    if (!el) return;
    try {
      var center = JSON.parse(el.dataset.center);
      var radiusMiles = parseFloat(el.dataset.radius);
      var radiusMeters = radiusMiles * 1609.34;
      var map = window.L.map(el, { center: [center.lat, center.lng], zoom: 8, zoomControl: false, scrollWheelZoom: false, dragging: false });
      window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; <a href="https://openstreetmap.org/copyright">OSM</a>', maxZoom: 18 }).addTo(map);
      window.L.circle([center.lat, center.lng], { radius: radiusMeters, color: '#b78330', fillColor: '#b78330', fillOpacity: 0.12, weight: 2 }).addTo(map);
    } catch(e) { console.error('Map init failed', e); }
  })();
</script>

<style>
  .contact {
    background-color: var(--color-cream);
    padding: var(--section-padding);
  }

  .contact__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .contact__header {
    text-align: center;
    margin-bottom: 56px;
  }

  .contact__title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 16px;
  }

  .contact__sub {
    font-size: 1rem;
    color: var(--color-navy);
    opacity: 0.7;
    max-width: 480px;
    margin: 0 auto;
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 48px;
    align-items: start;
  }

  .contact__info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .contact__card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background-color: var(--color-white);
    border: 1px solid rgba(30, 45, 61, 0.1);
    border-left: 4px solid var(--color-gold);
    border-radius: 6px;
    padding: 20px 24px;
    transition: transform 0.2s;
    color: var(--color-navy);
  }

  .contact__card:hover {
    transform: translateX(4px);
  }

  .contact__card--map:hover {
    transform: none;
  }

  .contact__card--map .contact__card-label {
    margin-bottom: 2px;
  }

  .contact__card--map .contact__card-value {
    font-weight: 500;
    font-size: 0.9rem;
    opacity: 0.8;
    margin-bottom: 12px;
  }

  .contact__map {
    width: 100%;
    height: 200px;
    border-radius: 4px;
    overflow: hidden;
  }

  .contact__card-icon {
    width: 24px;
    height: 24px;
    color: var(--color-gold);
    margin-bottom: 4px;
  }

  .contact__card-label {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-weight: 600;
  }

  .contact__card-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-navy);
    line-height: 1.5;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    background-color: var(--color-white);
    border: 1px solid rgba(30, 45, 61, 0.1);
    border-radius: 6px;
    padding: 36px;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .contact__field label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-navy);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .contact__field input,
  .contact__field textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-navy);
    background-color: var(--color-cream);
    border: 1px solid rgba(30, 45, 61, 0.2);
    border-radius: 4px;
    padding: 12px 16px;
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }

  .contact__field input:focus,
  .contact__field textarea:focus {
    border-color: var(--color-gold);
  }

  .contact__field input[aria-invalid="true"],
  .contact__field textarea[aria-invalid="true"] {
    border-color: var(--color-navy);
    background-color: #f4ece4;
  }

  .contact__error {
    font-size: 0.8rem;
    color: var(--color-navy);
  }

  .contact__error[aria-live="polite"]:not(:empty) {
    font-weight: 600;
  }

  .contact__error--banner {
    background-color: var(--color-navy);
    color: var(--color-cream);
    padding: 12px 16px;
    border-radius: 4px;
    font-size: 0.9rem;
    text-align: center;
  }

  .contact__error--banner:not([hidden]) {
    display: block;
  }

  .contact__honeypot {
    position: absolute;
    left: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
  }

  .btn--loading {
    pointer-events: none;
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .btn--loading .btn__text {
    opacity: 0.7;
  }

  .btn__spinner {
    display: none;
    animation: spin 0.8s linear infinite;
  }

  .btn--loading .btn__spinner {
    display: inline-block;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 768px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('contactForm');
  const submitBtn = document.getElementById('submitBtn');
  const submitText = submitBtn?.querySelector('.btn__text');
  const formError = document.getElementById('formError');

  const fields = [
    { id: 'name', validate: (v) => v.trim() ? '' : 'Name is required' },
    { id: 'email', validate: (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) ? '' : 'Enter a valid email address' },
    { id: 'phone', validate: (v) => !v || /^[\d\s\-.()]{7,}$/.test(v) ? '' : 'Enter a valid phone number', optional: true },
    { id: 'boat', validate: (v) => v.trim() ? '' : 'Let us know what kind of boat you have' },
    { id: 'message', validate: (v) => v.trim().length >= 10 ? '' : 'Please include a few more details' },
  ];

  function validateField(field) {
    const input = document.getElementById(field.id);
    const error = document.getElementById(field.id + 'Error');
    const msg = field.validate(input.value);
    error.textContent = msg;
    input.setAttribute('aria-invalid', msg ? 'true' : 'false');
    return !msg;
  }

  fields.forEach((f) => {
    const input = document.getElementById(f.id);
    input.addEventListener('blur', () => validateField(f));
    input.addEventListener('input', () => {
      if (input.hasAttribute('aria-invalid')) validateField(f);
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const honeypot = form.querySelector('input[name="_gotcha"]');
    if (honeypot?.value) return;

    const valid = fields.every((f) => validateField(f));
    if (!valid) return;

    submitBtn.classList.add('btn--loading');
    if (submitText) submitText.textContent = 'Sending...';
    formError.hidden = true;

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' },
      });
      if (res.ok) {
        window.location.href = form.querySelector('input[name="_next"]').value;
      } else {
        const data = await res.json();
        throw new Error(data?.error || 'Server error');
      }
    } catch (err) {
      formError.textContent = 'Something went wrong. Please try again or call (910) 465-1175.';
      formError.hidden = false;
      submitBtn.classList.remove('btn--loading');
      if (submitText) submitText.textContent = 'Send Message';
    }
  });
</script>

