---
interface Props {
  title?: string;
  noindex?: boolean;
}

const { title = "Technique Marine | Mobile Marine Service & Delivery, Cape Fear NC", noindex } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const IS_PROD = import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Mobile marine repair, maintenance, and delivery captain serving Cape Fear, NC and surrounding areas. One call solves it all." />
    <meta name="theme-color" content="#1e2d3d" />

    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Mobile marine repair, maintenance, electronics, and delivery captain. Serving Cape Fear, NC." />
    <meta property="og:type" content="website" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Technique Marine",
        "description": "Mobile marine repair, maintenance, and delivery captain serving Cape Fear, NC",
        "telephone": "(910) 465-1175",
        "email": "dylan@techniquemarine.com",
        "areaServed": "Cape Fear, NC",
        "url": "https://techniquemarine.com"
      }
    </script>

    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <title>{title}</title>

    <style is:global>
      :root {
        --color-navy: #1e2d3d;
        --color-steel: #7a9bb5;
        --color-gold: #b78330;
        --color-cream: #f4f1e4;
        --color-white: #ffffff;
        --font-display: system-ui, sans-serif;
        --font-body: system-ui, sans-serif;
        --max-width: 1100px;
        --section-padding: 80px 24px;
        --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
        --ease-out-quint: cubic-bezier(0.22, 1, 0.36, 1);
        --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
        --ease-drift: cubic-bezier(0.19, 0.72, 0.27, 1);
        --z-skip-link: 100;
        --z-sticky: 200;
        --z-dropdown: 300;
        --z-modal-backdrop: 400;
        --z-modal: 500;
        --z-toast: 600;
        --z-tooltip: 700;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: var(--font-body);
        background-color: var(--color-white);
        color: var(--color-navy);
        line-height: 1.6;
      }

      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; display: block; }

      .skip-link {
        position: absolute;
        top: -100%;
        left: 16px;
        z-index: var(--z-skip-link);
        background-color: var(--color-gold);
        color: var(--color-navy);
        padding: 8px 16px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.875rem;
        transition: top 0.15s;
      }
      .skip-link:focus {
        top: 8px;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: var(--section-padding);
      }

      .btn {
        display: inline-block;
        background-color: var(--color-gold);
        color: var(--color-navy);
        padding: 12px 28px;
        border-radius: 4px;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        font-size: 0.875rem;
        cursor: pointer;
        border: none;
        transition: opacity 0.2s;
      }

      .btn:hover { opacity: 0.88; }

      .btn:focus-visible {
        outline: 2px solid var(--color-gold);
        outline-offset: 2px;
      }

      h1, h2, h3 {
        font-family: var(--font-display);
      }

      /* Scroll reveals */
      .reveal {
        opacity: 0;
        transition: opacity 0.9s var(--ease-drift), transform 0.9s var(--ease-drift);
      }

      .reveal--fade-up {
        transform: translateY(30px);
      }

      .reveal--fade-left {
        transform: translateX(-30px);
      }

      .reveal--fade-right {
        transform: translateX(30px);
      }

      .reveal--drift {
        transform: translateY(30px) translateX(var(--drift-x, 0px));
      }

      .reveal--visible {
        opacity: 1;
        transform: translate(0);
      }

      .stagger-children > * {
        transition-delay: calc(var(--i, 0) * 90ms);
      }

      /* Consent banner */
      .consent-banner {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: var(--z-toast);
        background-color: var(--color-navy);
        color: var(--color-cream);
        padding: 18px 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
        font-size: 0.9rem;
        line-height: 1.6;
        box-shadow: 0 -6px 20px rgba(0,0,0,0.2);
        border-top: 2px solid var(--color-gold);
      }

      .consent-banner__text {
        flex: 1;
        min-width: 220px;
      }

      .consent-banner__link {
        color: var(--color-gold);
        font-weight: 600;
      }
      .consent-banner__link:hover {
        text-decoration: underline;
      }

      .consent-banner__actions {
        display: flex;
        gap: 12px;
        flex-shrink: 0;
      }

      .consent-banner__btn {
        padding: 10px 24px;
        border: none;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 700;
        cursor: pointer;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        transition: opacity 0.2s;
      }
      .consent-banner__btn:hover {
        opacity: 0.85;
      }

      .consent-banner__btn--accept {
        background-color: var(--color-gold);
        color: var(--color-navy);
      }

      .consent-banner__btn--reject {
        background-color: transparent;
        color: var(--color-steel);
        border: 1px solid var(--color-steel);
      }
      .consent-banner__btn--reject:hover {
        color: var(--color-cream);
        border-color: var(--color-cream);
        opacity: 1;
      }

      @media (max-width: 500px) {
        .consent-banner {
          flex-direction: column;
          text-align: center;
          padding: 16px 20px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
        .reveal {
          opacity: 1;
          transform: none;
        }
      }
    </style>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />

    <div class="consent-banner" id="consentBanner" role="dialog" aria-label="Cookie consent">
      <p class="consent-banner__text">
        This site uses analytics cookies to improve your experience. <a href="/privacy" class="consent-banner__link">Privacy Policy</a>.
      </p>
      <div class="consent-banner__actions">
        <button class="consent-banner__btn consent-banner__btn--accept" id="consentAccept">Accept</button>
        <button class="consent-banner__btn consent-banner__btn--reject" id="consentReject">Reject</button>
      </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('reveal--visible');
            } else {
              entry.target.classList.remove('reveal--visible');
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('.reveal').forEach(function(el) {
          observer.observe(el);
        });
      });
    </script>

    <script>
      (function() {
        var GA_ID = 'G-FE89TG42ZQ';
        var KEY = 'consent';
        var IS_PROD = {IS_PROD};

        function getConsent() {
          return localStorage.getItem(KEY);
        }

        function setConsent(value) {
          localStorage.setItem(KEY, value);
        }

        function loadGA() {
          if (!IS_PROD) return;
          if (window.__gtagLoaded) return;
          window.__gtagLoaded = true;

          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
          document.head.appendChild(s);

          window.dataLayer = window.dataLayer || [];
          function gtag(){ dataLayer.push(arguments); }
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', GA_ID, { 'anonymize_ip': true });
        }

        function hideBanner() {
          var banner = document.getElementById('consentBanner');
          if (banner) banner.style.display = 'none';
        }

        var existing = getConsent();
        if (existing === 'accepted') {
          loadGA();
          hideBanner();
        } else if (existing === 'rejected') {
          hideBanner();
        } else {
          document.getElementById('consentAccept').addEventListener('click', function() {
            setConsent('accepted');
            loadGA();
            hideBanner();
          });
          document.getElementById('consentReject').addEventListener('click', function() {
            setConsent('rejected');
            hideBanner();
          });
        }
      })();
    </script>
  </body>
</html>
